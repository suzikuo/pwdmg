{
  "name": "mypwdmg-front",
  "version": "2.0.43",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --mode web --host 127.0.0.1",
    "dev:android": "vite --mode android --host 127.0.0.1",
    "dev:desktop": "vite --mode desktop --host 127.0.0.1",
    "dev:web": "vite --mode web --host 127.0.0.1",
    "typecheck": "vue-tsc --noEmit",
    "build": "npm run build:all",
    "build:all": "npm run typecheck && vite build --mode android && vite build --mode desktop && vite build --mode web",
    "build:android": "npm run typecheck && vite build --mode android",
    "build:desktop": "npm run typecheck && vite build --mode desktop",
    "build:web": "npm run typecheck && vite build --mode web",
    "preview": "vite preview --mode web --host 127.0.0.1",
    "preview:android": "vite preview --mode android --host 127.0.0.1",
    "preview:desktop": "vite preview --mode desktop --host 127.0.0.1",
    "preview:web": "vite preview --mode web --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "typescript": "^6.0.3",
    "vant": "^4.10.0",
    "vite": "^8.1.3",
    "vue": "^3.5.39",
    "vue-tsc": "^3.3.6"
  },
  "devDependencies": {}
}
